# Rafay API proxy configuration — copy to .env and fill in.
# .env is gitignored; never commit real keys.

# Base URL of the Rafay console, no trailing slash.
API_URL=https://console.gruve-ctl.paas.dev.rafay-edge.net

# Rafay API key (X-API-KEY header). Secret — do not commit.
API_KEY=replace-me

# Base name for the log file. Logs are written to /tmp/<LOG_FILE_NAME>.log
LOG_FILE_NAME=rafay-api-poc
